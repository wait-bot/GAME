function loadBossImages() {
    for (var wave in BOSS_CONFIG) {
        var config = BOSS_CONFIG[wave];
        if (config.imagePath) {
            var img = new Image();
            img.onload = function() {
                console.log('Boss image loaded successfully:', this.src);
            };
            img.onerror = function() {
                console.error('Failed to load boss image:', this.src);
            };
            img.src = config.imagePath;
            bossImages[wave] = img;
        }
    }
}

